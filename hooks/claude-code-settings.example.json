{
  "mcpServers": {
    "open-memory": {
      "command": "python",
      "args": ["-m", "src.server"],
      "cwd": "/path/to/open-memory",
      "env": {
        "DB_HOST": "localhost",
        "DB_PORT": "5432",
        "DB_NAME": "open_memory",
        "DB_USER": "memory_user",
        "DB_PASSWORD": "changeme",
        "EMBEDDING_MODEL": "google/embeddinggemma-300m",
        "EMBEDDING_DIM": "256",
        "DUAL_EMBEDDING": "true",
        "CODE_EMBEDDING_MODEL": "nomic-ai/CodeRankEmbed",
        "CODE_EMBEDDING_DIM": "768",
        "MCP_TRANSPORT": "stdio"
      }
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/path/to/open-memory/hooks/session_start.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 /path/to/open-memory/hooks/session_stop.py",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
