{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "/path/to/open-memory/hooks/session_start.sh",
        "timeout": 15
      }
    ],
    "stop": [
      {
        "command": "python3 /path/to/open-memory/hooks/session_stop.py",
        "timeout": 10
      }
    ],
    "postToolUse": [
      {
        "command": "python3 /path/to/open-memory/hooks/post_tool_use.py",
        "timeout": 5
      }
    ]
  }
}
